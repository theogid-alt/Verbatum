# Demo transport
# V2 default is the custom Pipecat cascade on LiveKit. Hume remains selectable in the UI.
VERBATIM_TRANSPORT_PROVIDER=livekit

# Daily WebRTC transport
DAILY_API_KEY=
DAILY_ROOM_URL=
DAILY_ROOM_TOKEN=
# Leave blank for Daily/provider auto-region. Use the UI buttons only when testing regions.
DAILY_GEO=
VERBATIM_DAILY_FORCE_CREATE_ROOM=false

# LiveKit WebRTC transport
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_URL=
LIVEKIT_ROOM_NAME=
LIVEKIT_EMPTY_TIMEOUT_SECONDS=600
LIVEKIT_MAX_PARTICIPANTS=4
LIVEKIT_TOKEN_TTL_SECONDS=3600
VERBATIM_LIVEKIT_AUDIO_IN_SAMPLE_RATE=
VERBATIM_LIVEKIT_AUDIO_OUT_SAMPLE_RATE=
VERBATIM_LIVEKIT_AUDIO_OUT_BITRATE=96000
VERBATIM_LIVEKIT_AUDIO_OUT_10MS_CHUNKS=4
VERBATIM_LIVEKIT_AUDIO_OUT_AUTO_SILENCE=true
VERBATIM_LIVEKIT_BROWSER_ECHO_CANCELLATION=true
VERBATIM_LIVEKIT_BROWSER_NOISE_SUPPRESSION=true
VERBATIM_LIVEKIT_BROWSER_AUTO_GAIN_CONTROL=true
VERBATIM_LIVEKIT_BROWSER_AUDIO_SAMPLE_RATE=48000

# Provider credentials
DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
ULTRAVOX_API_KEY=
HUME_API_KEY=
HUME_SECRET_KEY=
HUME_EVI_CONFIG_ID=
HUME_EVI_CONFIG_VERSION=
HUME_EVI_USE_CONFIG=false
HUME_EVI_VOICE_ID=
HUME_EVI_VERBOSE_TRANSCRIPTION=true
HUME_EVI_SEND_SYSTEM_PROMPT=true
HUME_EVI_SYSTEM_PROMPT="You are a friendly real estate voice assistant. Stay focused on property questions, prices, listings, viewings, availability, and next steps. Keep replies short: one or two spoken sentences. Do not start every answer with okay. Vary naturally, and often answer directly. Do not interrupt. Wait until the caller finishes. Answer the question first. If details are missing, say so briefly and offer SMS follow-up. After discussing a specific property, gently offer to book a property viewing. After a viewing is booked, offer to send an SMS confirmation. Do not force qualification questions or drift into unrelated topics. Do not claim a company, city, or name unless provided."
CARTESIA_API_KEY=

# Optional client-owned integrations for tool calling
# Tool calling is on by default when a compatible calendar connection exists.
NANGO_SECRET_KEY=
NANGO_API_BASE_URL=https://api.nango.dev
NANGO_GOOGLE_CALENDAR_INTEGRATION_ID=google-calendar
NANGO_CALENDLY_INTEGRATION_ID=calendly
NANGO_SALESFORCE_INTEGRATION_ID=salesforce
NANGO_HUBSPOT_INTEGRATION_ID=hubspot
NANGO_PIPEDRIVE_INTEGRATION_ID=pipedrive
NANGO_SLACK_INTEGRATION_ID=slack
NANGO_GMAIL_INTEGRATION_ID=gmail
NANGO_OUTLOOK_CALENDAR_INTEGRATION_ID=outlook
NANGO_GOOGLE_SHEETS_INTEGRATION_ID=google-sheets
NANGO_AIRTABLE_INTEGRATION_ID=airtable
NANGO_NOTION_INTEGRATION_ID=notion
NANGO_STRIPE_INTEGRATION_ID=stripe
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
MAKE_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=
N8N_WEBHOOK_URL=
VERBATIM_WEBHOOK_URL=
ZENCHEF_API_KEY=
THEFORK_API_KEY=
WHATSAPP_BUSINESS_ACCESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
STRIPE_API_KEY=
VERBATIM_FOLLOWUP_SMS_DEFAULT_BODY="Thanks for calling. I will send the property details here shortly."
VERBATIM_DEFAULT_CLIENT_ID=demo
VERBATIM_TOOLS_ENABLED=true
VERBATIM_TOOL_TIMEOUT_MS=2500
VERBATIM_INTEGRATIONS_DB_PATH=./data/verbatim/integrations_v2.db
VERBATIM_CLIENT_CONFIG_DIR=./client

# Agent identity
VERBATIM_AGENT_ID=agent_demo
VERBATIM_CLIENT_ID=internal
VERBATIM_ENV=development
VERBATIM_LOG_LEVEL=debug
VERBATIM_USER_TURN_STOP_TIMEOUT=5.0
VERBATIM_LLM_HISTORY_MESSAGES=1

# Provider models and behavior
VERBATIM_CARTESIA_VOICE_ID=
VERBATIM_CARTESIA_MODEL=sonic-3
VERBATIM_LLM_PROVIDER=groq
VERBATIM_GEMINI_MODEL=gemini-2.5-flash
VERBATIM_OPENAI_MODEL=gpt-4o-mini
VERBATIM_GROQ_MODEL=llama-3.1-8b-instant
VERBATIM_QWEN_MODEL=qwen3.5-2b
VERBATIM_XAI_MODEL=grok-4-1-fast-non-reasoning
VERBATIM_ULTRAVOX_MODEL=fixie-ai/ultravox
# Use the UltraVox voice UUID, not the underlying ElevenLabs/Cartesia/etc provider voice id.
VERBATIM_ULTRAVOX_VOICE_ID=
VERBATIM_ULTRAVOX_MAX_DURATION_SECONDS=3600
VERBATIM_ULTRAVOX_TURN_ENDPOINT_DELAY_SECONDS=
VERBATIM_ULTRAVOX_MINIMUM_TURN_DURATION_SECONDS=
VERBATIM_ULTRAVOX_MINIMUM_INTERRUPTION_DURATION_SECONDS=
VERBATIM_ULTRAVOX_FRAME_ACTIVATION_THRESHOLD=
VERBATIM_ULTRAVOX_CLIENT_BUFFER_SIZE_MS=
VERBATIM_ULTRAVOX_MEDIA_IDLE_TIMEOUT_SECONDS=
VERBATIM_MOCK_LLM_RESPONSE="Got it. I can help with that."
VERBATIM_DEEPGRAM_MODEL=nova-3-general
VERBATIM_STT_PROVIDER=deepgram
VERBATIM_TTS_TEXT_AGGREGATION_MODE=sentence
VERBATIM_CARTESIA_MAX_BUFFER_DELAY_MS=100
VERBATIM_DEEPGRAM_ENDPOINTING=100
VERBATIM_DEEPGRAM_UTTERANCE_END_MS=1000
VERBATIM_DEEPGRAM_FLUX_EAGER_EOT_THRESHOLD=0.45
VERBATIM_DEEPGRAM_FLUX_EOT_THRESHOLD=0.75
VERBATIM_DEEPGRAM_FLUX_EOT_TIMEOUT_MS=1200
VERBATIM_DEEPGRAM_FLUX_MIN_CONFIDENCE=

# Prompt
VERBATIM_SYSTEM_PROMPT="You are a sharp real estate voice assistant. Answer the caller's actual question first. Do not block simple questions behind qualification questions. If they ask for price, answer or say you can send it by SMS. After discussing a specific property, gently offer to book a property viewing. After a viewing is booked, offer to send an SMS confirmation. Ask at most one useful follow-up question. Do not repeat or rephrase what the caller said. Avoid form-like questions unless the caller asks for recommendations. Keep replies very short, usually 4-14 words, max two short sentences. Do not claim a company, city, or name unless provided."
VERBATIM_LLM_MAX_TOKENS=32
VERBATIM_LLM_TEMPERATURE=0
VERBATIM_GREETING="Hi, how can I help?"

# Local instrumentation
VERBATIM_ENABLE_JSONL_EVENTS=true
VERBATIM_EVENT_LOG_PATH=./data/verbatim/events_v2_clean.jsonl
VERBATIM_CALL_SUMMARY_DIR=./data/verbatim/calls_v2_clean
VERBATIM_TRANSCRIPT_DIR=./data/verbatim/transcripts_v2_clean
